# ─────────────────────────────────────────────────────────────
# PRIMESTACK Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ─────────────────────────────────────────────────────────────

# App
APP_ENV=development
PORT=8080

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/primestack?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-strong-random-string-min-32-chars
JWT_EXPIRY_HOURS=24

# Admin fallback credentials (dev only)
ADMIN_EMAIL=admin@primestack.uz
ADMIN_PASSWORD=admin123

# CORS
ALLOWED_ORIGIN=http://localhost:3000
# Multiple origins (comma-separated), e.g. https://primestack.uz,https://www.primestack.uz
ALLOWED_ORIGINS=

# S3 / MinIO Storage
S3_BUCKET=primestack-media
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=primestack
AWS_SECRET_ACCESS_KEY=primestack123

# Upload limits
MAX_UPLOAD_SIZE_MB=10

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMTP Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
