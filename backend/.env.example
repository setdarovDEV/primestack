# ─────────────────────────────────────────────────────────────
# PRIMESTACK Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ─────────────────────────────────────────────────────────────

# App
APP_ENV=development
PORT=8080

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/primestack?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-strong-random-string-min-32-chars
JWT_EXPIRY_HOURS=8

# Admin fallback credentials (disabled by default, dev only)
ADMIN_EMAIL=admin@primestack.uz
ADMIN_PASSWORD=
ALLOW_ENV_ADMIN_FALLBACK=false

# Auth cookies / CSRF
AUTH_COOKIE_NAME=admin_token
AUTH_CSRF_COOKIE_NAME=admin_csrf
AUTH_COOKIE_DOMAIN=
# Production'da true bo'lishi shart (HTTPS)
AUTH_COOKIE_SECURE=false
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# CORS
ALLOWED_ORIGIN=http://localhost:3000
# Multiple origins (comma-separated), e.g. https://primestack.uz,https://www.primestack.uz
# Production uchun odatda:
# ALLOWED_ORIGINS=https://primestack.uz,https://www.primestack.uz
ALLOWED_ORIGINS=
# Agar reverse proxy ishlatilsa (masalan Nginx), shu yerga trusted CIDR/IP larni kiriting.
# Misol: TRUSTED_PROXIES=127.0.0.1,172.16.0.0/12
TRUSTED_PROXIES=

# S3 / MinIO Storage
S3_BUCKET=primestack-media
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=primestack
AWS_SECRET_ACCESS_KEY=primestack123

# Upload limits
MAX_UPLOAD_SIZE_MB=10

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional webhook secret token.
# Webhook URL example:
# https://api.primestack.uz/api/v1/telegram/webhook/<TELEGRAM_WEBHOOK_SECRET>
TELEGRAM_WEBHOOK_SECRET=
# Railway/public backend URL (if set, backend startup will auto call Telegram setWebhook)
# Example: https://gracious-nurturing-production.up.railway.app
TELEGRAM_WEBHOOK_BASE_URL=

# SMTP Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Admin 2FA
# Login kodi doim shu emailga yuboriladi.
ADMIN_2FA_EMAIL=abbossetdarov3@gmail.com
ADMIN_2FA_CODE_EXPIRY_MINUTES=10
ADMIN_2FA_MAX_ATTEMPTS=5
